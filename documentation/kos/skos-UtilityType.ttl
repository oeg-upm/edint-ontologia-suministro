@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintutiltype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/UtilityType/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:UtilityType a skos:ConceptScheme ; 
    dct:issued "2026-03-23"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Tipo de suministro"@en ;
    rdfs:label "Utility type"@es ;
    skos:hasTopConcept edintutiltype:energy;
    dct:title "Concept scheme grouping types of utilities supplied to the municipality's infrastructure elements."@en ;
    dct:title "Esquema de conceptos agrupando tipos de suministros a los elemementos de la infraestructura de un municipio."@es .
    

#################################################################
#
#    Concepts
#
#################################################################

edintutiltype:energy a skos:Concept;
  skos:inScheme edintkos:UtilityType;
  skos:prefLabel "Energía"@es ;
  skos:prefLabel "Energy"@en .

edintutiltype:activeenergy a skos:Concept;
  skos:inScheme edintkos:UtilityType;
  skos:broader edintutiltype:energy;
  skos:prefLabel "Active energy"@es ;
  skos:prefLabel "Energía activa"@en .

  edintutiltype:reactiveenergy a skos:Concept;
  skos:inScheme edintkos:UtilityType;
  skos:broader edintutiltype:energy;
  skos:prefLabel "Reactive energy"@es ;
  skos:prefLabel "Energía reactiva"@en .

edintutiltype:gas a skos:Concept;
  skos:inScheme edintkos:UtilityType;
  skos:broader edintutiltype:energy;
  skos:prefLabel "Gas"@es ;
  skos:prefLabel "Gas"@en .






