@prefix : <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/suministro#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/suministro#> .

<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/suministro> rdf:type owl:Ontology ;
                                                                                      owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/suministro/0.1.0> ;
                                                                                      <http://purl.org/dc/terms/created> "2026-03-23" ;
                                                                                      <http://purl.org/dc/terms/creator> "Daniel Doña" ,
                                                                                                                         "Edna Ruckhaus" ,
                                                                                                                         "Lucía Sánchez" ,
                                                                                                                         "Oscar Corcho" ,
                                                                                                                         "Socorro Bernardos" ;
                                                                                      <http://purl.org/dc/terms/description> "La ontología de suministros describe todos los conceptos relacionados con los servicios suministrados a los elementos de la infraestructura de un municipio y la medición de su consumo. Su alcance es el de suministros como electricidad, gas, agua, entre otros."@es ,
                                                                                                                             "The Utilities ontology describes all concepts related to the utilities provided to a municipality's infrastructure elements and the measurement of their consumption. Its scope covers utilities such as electricity, gas, water, and others."@en ;
                                                                                      <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                                      <http://purl.org/dc/terms/title> "Ontología de Suministros"@es ,
                                                                                                                       "The Utilities Ontology"@en ;
                                                                                      <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintsum" ;
                                                                                      <http://purl.org/vocab/vann/preferredNamespaceUri> : ;
                                                                                      owl:versionInfo "0.1.0" .

