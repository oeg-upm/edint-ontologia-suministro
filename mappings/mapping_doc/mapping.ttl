@prefix edintsum: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/suministro#>.
@prefix edintutiltype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/UtilityType/>.
@prefix edintinf: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#>.
@prefix sosa: <http://www.w3.org/ns/sosa/>.
@prefix edintmetertype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/MeterType/>.
@prefix schema: <https://schema.org/>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix esdir: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#>.
@prefix geosparql: <http://www.opengis.net/ont/geosparql#>.
@prefix ester: <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#>.
@prefix qudt: <http://qudt.org/schema/qudt/>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix formats: <http://www.w3.org/ns/formats/>.
@prefix comp: <http://semweb.mmlab.be/ns/rml-compression#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#>.
@prefix map: <http://mapping.example.com/> .
@base <http://example.com/ns#>.

map:person_000 dct:contributor foaf:Person ;
    rdfs:label "Jhon Toledo" ;
    foaf:mbox <mailto:ja.toledo@upm.es> .

map:rules_000 schema:contributor map:person_000 ;
    rdf:type schema:Dataset ;
    schema:version "1.0.0" ;
    schema:title "Mappings RML para transformar datos de suministro a RDF (EDINT Suministro)" ;
    schema:dateCreated "30-03-2026" ;
    schema:description "Este conjunto de mappings RML transforma datos relacionados con los servicios suministrados a los elementos de la infraestructura de un municipio y la medición de su consumo a RDF, utilizando la ontología EDINT Suministro. El objetivo es generar un grafo RDF interoperable para representar las entidades principales asociadas a suministros como electricidad, gas y agua, orientado a la gestión del consumo de recursos en el contexto de las funciones habituales de las entidades locales." .
<utilitysupplyPoint_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "data.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/puntoSuministro/{CUPS}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant edintsum:UtilitySupplyPoint;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dct:identifier;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "CUPS";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdfs:label;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "Punto de Suministro {CUPS}, Descripción/Grupo: {GRUPO}";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintsum:hasUtilityType;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/kos/edint/UtilityType/{CLASE}";
			rr:termType rr:IRI
		];
	].


<infra_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "data.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/equipamientoMunicipal/{ID}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant edintinf:InfrastructureElement;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintsum:hasUtilitySupplyPoint;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/puntoSuministro/{CUPS}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dct:identifier;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "ID";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdfs:label;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "EDIFICIO";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant schema:address;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/direccion-postal/{CODIGO_POSTAL}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintinf:belongsTo;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/barrio/{CÓDIGO BARRIO}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant geosparql:hasGeometry;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/equipamiento-municipal/locations/{COORDENADA-X}-{COORDENADA-Y}";
			rr:termType rr:IRI
		];
	].


