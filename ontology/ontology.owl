        <AbbreviatedIRI>sosa:hasResult</AbbreviatedIRI>
        <Literal xml:lang="en">Relation linking an Observation or Actuation or act of Sampling and a Result or Sample.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
