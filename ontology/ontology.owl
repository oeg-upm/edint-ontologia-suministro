        <AbbreviatedIRI>sosa:hasSimpleResult</AbbreviatedIRI>
        <Literal xml:lang="en">For instance, the values 23 or true.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>sosa:madeBySensor</AbbreviatedIRI>
        <Literal xml:lang="es">Relación entre una observación y el sensor que realiza la observación.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <AbbreviatedIRI>sosa:madeBySensor</AbbreviatedIRI>
        <AbbreviatedIRI>sosa:</AbbreviatedIRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>sosa:madeBySensor</AbbreviatedIRI>
        <Literal xml:lang="en">made by sensor or observer</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>sosa:madeBySensor</AbbreviatedIRI>
        <Literal xml:lang="es">realizado por sensor u observador</Literal>
