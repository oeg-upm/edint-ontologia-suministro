        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <AbbreviatedIRI>sosa:ObservationCollection</AbbreviatedIRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="schema:domainIncludes"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <AbbreviatedIRI>sosa:Sampling</AbbreviatedIRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <Literal xml:lang="es">El momento en que el resultado de una observación, actuación o muestreo se aplica a la entidad de interés. No necesariamente coincide con el momento del resultado. Puede ser un intervalo, un instante o alguna otra entidad temporal compuesta.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <Literal xml:lang="en">The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <AbbreviatedIRI>sosa:</AbbreviatedIRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <IRI>http://www.w3.org/ns/sosa/common/</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <Literal xml:lang="es">momento del fenómeno</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <Literal xml:lang="en">phenomenon time</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <Literal xml:lang="en">The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="schema:domainIncludes"/>
        <AbbreviatedIRI>sosa:resultTime</AbbreviatedIRI>
        <AbbreviatedIRI>sosa:Actuation</AbbreviatedIRI>
