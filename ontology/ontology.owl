    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>dcterms:identifier</AbbreviatedIRI>
        <Literal xml:lang="en">An unambiguous reference to the resource within a given context.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>dcterms:identifier</AbbreviatedIRI>
        <Literal xml:lang="es">Una referencia no ambigüa al recurso dentro de un contexto determinado.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <AbbreviatedIRI>dcterms:identifier</AbbreviatedIRI>
        <AbbreviatedIRI>dcterms:</AbbreviatedIRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>dcterms:identifier</AbbreviatedIRI>
        <Literal xml:lang="es">identificador</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
