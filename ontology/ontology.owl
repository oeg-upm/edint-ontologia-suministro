        <AbbreviatedIRI>sosa:observes</AbbreviatedIRI>
        <Literal xml:lang="es">observa</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>sosa:observes</AbbreviatedIRI>
        <Literal xml:lang="en">observes</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="schema:domainIncludes"/>
        <AbbreviatedIRI>sosa:phenomenonTime</AbbreviatedIRI>
        <AbbreviatedIRI>sosa:Actuation</AbbreviatedIRI>
